{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Holad",
  "version": "0.1.0",
  "identifier": "com.holad.desktop",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Holad",
        "visible": false,
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "theme": "Dark",
        "userAgent": "Holad-Desktop",
        "backgroundColor": [
          18,
          18,
          18,
          255
        ]
      },
      {
        "label": "tray_menu",
        "title": "Tray Menu",
        "url": "/#tray",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 320,
        "height": 450,
        "resizable": false,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "resources": [
      "icons/taskbar/*"
    ]
  },
  "plugins": {}
}